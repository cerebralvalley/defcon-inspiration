{
  "name": "@cerebralvalley/defcon-inspiration",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "DEF CON talk idea index, transcripts, dashboard, and local search CLI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cerebralvalley/defcon-inspiration.git"
  },
  "homepage": "https://defcon-inspiration.cerebralvalley.ai",
  "license": "MIT",
  "files": [
    "api",
    "data/defcon-all-v1",
    "scripts",
    "src",
    ".env.example",
    "ideas.html",
    "vercel.json",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "defcon-search": "src/defcon/search.mjs",
    "defcon-snippets": "scripts/grep-snippets.mjs"
  },
  "scripts": {
    "build": "node scripts/build-static.mjs",
    "check": "node --check api/status.js && node --check src/defcon/search.mjs && node --check scripts/grep-snippets.mjs",
    "search": "node src/defcon/search.mjs",
    "snippets": "node scripts/grep-snippets.mjs"
  },
  "dependencies": {
    "dotenv": "^16.6.1"
  }
}
